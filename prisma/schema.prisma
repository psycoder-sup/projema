// Prisma schema for Sprint Todo Management
// NOTE: Do NOT use @updatedAt on any model — updated_at is maintained by
// a Postgres BEFORE UPDATE trigger (trg_set_updated_at_<table>). This is
// enforced by a lint check in CI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Domain Models — Phase 1
// ============================================================================
// NOTE: No @updatedAt directive on any model — DB triggers handle updated_at.

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  displayName String    @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  role        String    @default("member")
  isActive    Boolean   @default(true) @map("is_active")
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  accounts           Account[]
  sessions           Session[]
  allowlistAdded     AllowlistEntry[] @relation("AllowlistAddedBy")
  sessionsLog        SessionsLog[]
  sprintsCreated     Sprint[]         @relation("SprintCreatedBy")
  todosAssigned      Todo[]           @relation("TodoAssignee")
  todosCreated       Todo[]           @relation("TodoCreatedBy")
  activityEvents     ActivityEvent[]  @relation("ActivityActor")
  todoDocuments      TodoDocument[]   @relation("TodoDocumentUpdatedBy")

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AllowlistEntry {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  addedByUserId String   @map("added_by_user_id") @db.Uuid
  addedAt       DateTime @default(now()) @map("added_at") @db.Timestamptz

  addedBy User @relation("AllowlistAddedBy", fields: [addedByUserId], references: [id])

  @@map("allowlist_entries")
}

model SessionsLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  provider  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("sessions_log")
}

// ============================================================================
// Domain Models — Phase 2
// ============================================================================

model Sprint {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  startDate       DateTime  @map("start_date") @db.Date
  endDate         DateTime  @map("end_date") @db.Date
  status          String    @default("planned")
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  createdBy      User            @relation("SprintCreatedBy", fields: [createdByUserId], references: [id])
  goals          SprintGoal[]
  todos          Todo[]
  activityEvents ActivityEvent[] @relation("ActivityTargetSprint")

  @@index([status, startDate(sort: Desc)])
  @@map("sprints")
}

model SprintGoal {
  id        String   @id @default(uuid()) @db.Uuid
  sprintId  String   @map("sprint_id") @db.Uuid
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  sprint Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  todos  Todo[]

  @@index([sprintId, position])
  @@map("sprint_goals")
}

model Todo {
  id              String    @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  status          String    @default("todo")
  priority        String    @default("medium")
  assigneeUserId  String?   @map("assignee_user_id") @db.Uuid
  dueDate         DateTime? @map("due_date") @db.Date
  sprintId        String?   @map("sprint_id") @db.Uuid
  sprintGoalId    String?   @map("sprint_goal_id") @db.Uuid
  createdByUserId String    @map("created_by_user_id") @db.Uuid
  completedAt     DateTime? @map("completed_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  assignee        User?           @relation("TodoAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  sprint          Sprint?         @relation(fields: [sprintId], references: [id], onDelete: Restrict)
  sprintGoal      SprintGoal?     @relation(fields: [sprintGoalId], references: [id], onDelete: Restrict)
  createdBy       User            @relation("TodoCreatedBy", fields: [createdByUserId], references: [id])
  activityEvents  ActivityEvent[] @relation("ActivityTargetTodo")
  links           TodoLink[]
  document        TodoDocument?

  @@index([assigneeUserId, status, dueDate(sort: Asc)])
  @@index([sprintId, sprintGoalId])
  @@map("todos")
}

model TodoLink {
  id        String   @id @default(uuid()) @db.Uuid
  todoId    String   @map("todo_id") @db.Uuid
  url       String
  label     String?
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  todo Todo @relation(fields: [todoId], references: [id], onDelete: Cascade)

  @@index([todoId, position])
  @@map("todo_links")
}

model TodoDocument {
  todoId            String   @id @map("todo_id") @db.Uuid
  contentMarkdown   String   @map("content_markdown")
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz
  updatedByUserId   String   @map("updated_by_user_id") @db.Uuid

  todo          Todo @relation(fields: [todoId], references: [id], onDelete: Cascade)
  updatedByUser User @relation("TodoDocumentUpdatedBy", fields: [updatedByUserId], references: [id])

  @@map("todo_documents")
}

model ActivityEvent {
  id             String   @id @default(uuid()) @db.Uuid
  actorUserId    String   @map("actor_user_id") @db.Uuid
  kind           String
  targetTodoId   String?  @map("target_todo_id") @db.Uuid
  targetSprintId String?  @map("target_sprint_id") @db.Uuid
  payloadJson    Json?    @map("payload_json")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor       User   @relation("ActivityActor", fields: [actorUserId], references: [id])
  targetTodo  Todo?  @relation("ActivityTargetTodo", fields: [targetTodoId], references: [id], onDelete: SetNull)
  targetSprint Sprint? @relation("ActivityTargetSprint", fields: [targetSprintId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([targetTodoId, createdAt(sort: Desc)])
  @@map("activity_events")
}
