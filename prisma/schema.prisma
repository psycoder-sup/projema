// Prisma schema for Sprint Todo Management
// NOTE: Do NOT use @updatedAt on any model — updated_at is maintained by
// a Postgres BEFORE UPDATE trigger (trg_set_updated_at_<table>). This is
// enforced by a lint check in CI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Domain Models — Phase 1
// ============================================================================

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique
  displayName String    @map("display_name")
  avatarUrl   String?   @map("avatar_url")
  role        String    @default("member")
  isActive    Boolean   @default(true) @map("is_active")
  lastSeenAt  DateTime? @map("last_seen_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  accounts        Account[]
  sessions        Session[]
  allowlistAdded  AllowlistEntry[] @relation("AllowlistAddedBy")
  sessionsLog     SessionsLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime @db.Timestamptz
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AllowlistEntry {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  addedByUserId String   @map("added_by_user_id") @db.Uuid
  addedAt       DateTime @default(now()) @map("added_at") @db.Timestamptz

  addedBy User @relation("AllowlistAddedBy", fields: [addedByUserId], references: [id])

  @@map("allowlist_entries")
}

model SessionsLog {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  provider  String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("sessions_log")
}
