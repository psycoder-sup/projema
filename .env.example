# =============================================================================
# Sprint Todo Management — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local or .env to the repository.
# =============================================================================

# --- Database (Neon / PostgreSQL) ---
# Pooled URL used by Prisma at runtime (PgBouncer compatible)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Direct URL used only for migrations (bypasses PgBouncer)
DIRECT_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# --- Auth.js v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-minimum-32-characters-long

# Auth.js v5 base URL (formerly NEXTAUTH_URL)
AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- PostHog Analytics ---
# Server-side API key (not exposed to browser)
POSTHOG_API_KEY=phx_your_server_api_key

# Browser-facing public key
NEXT_PUBLIC_POSTHOG_KEY=phx_your_public_api_key

# PostHog host (use https://app.posthog.com for PostHog Cloud)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Application ---
# Full base URL of the deployed app (no trailing slash)
APP_BASE_URL=http://localhost:3000

# IANA timezone name for the org's calendar-date semantics (due dates, sprint dates)
# Default: UTC
ORG_TIMEZONE=UTC

# --- Vercel Cron ---
# Shared secret Vercel sets on scheduled invocations; /api/cron/* handlers reject without it.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex-string

# --- Sentry (optional in dev) ---
# Set SENTRY_ENABLED=true in development to enable Sentry locally
SENTRY_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=sprint-todo-management
SENTRY_AUTH_TOKEN=your-sentry-auth-token
